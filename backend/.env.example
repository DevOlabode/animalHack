# Database
DB_URL=mongodb://localhost:27017/animalhack

# Server
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
SESSION_SECRET=your-session-secret

# Email (Resend) — https://resend.com
# No custom domain needed for development.
# 1. Sign up at resend.com and create an API key
# 2. Use the default sender below (Resend's test address)
# 3. Without a verified domain, Resend only delivers to the email you signed up with
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=onboarding@resend.dev
