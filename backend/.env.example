# Database
DB_URL=mongodb://localhost:27017/animalhack

# Server
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
SESSION_SECRET=your-session-secret

# Email (Brevo) — https://www.brevo.com
# No custom domain needed. Verify a single sender email in Brevo:
#   Senders & IP → Senders → Add a sender → confirm via inbox link
# Then use that same email as EMAIL_FROM below.
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your-verified-email@gmail.com
EMAIL_FROM_NAME=PetCare
