# Database
DB_URL=mongodb://localhost:27017/animalhack

# Server
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-secret

# Email (Brevo) — https://www.brevo.com
# No custom domain needed. Verify a single sender email in Brevo:
#   Senders & IP → Senders → Add a sender → confirm via inbox link
# Then use that same email as EMAIL_FROM below.
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=your-verified-email@gmail.com
EMAIL_FROM_NAME=Vethra

# Demo data: npm run seed
# Creates demo@petowner.com, demo@happypaws.com, demo@westsidevet.com (password: demo123456)
# Seed is blocked when NODE_ENV=production unless ALLOW_SEED=true
# ALLOW_SEED=true
